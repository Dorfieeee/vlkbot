"""Entry point for the VIP Discord bot."""
import asyncio

from bot import get_api_client, get_bot, get_token


async def main() -> None:
    """Main entry point for the bot."""
    bot = get_bot()
    api_client = get_api_client()
    token = get_token()
    
    try:
        await bot.start(token)
    finally:
        await api_client.close()


if __name__ == "__main__":
    asyncio.run(main())
